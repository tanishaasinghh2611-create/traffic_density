# Sine wave(ideal Wave generated)

import numpy as np
import matplotlib.pyplot as plt

# Time axis
t = np.linspace(0, 1, 500)

# Generate sine wave
freq = 5
signal = np.sin(2 * np.pi * freq * t)

# Add noise
noise = np.random.normal(0, 0.5, t.shape)
noisy_signal = signal + noise

# Plot both signals
plt.figure(figsize=(10,5))

plt.subplot(2,1,1)
plt.title("Original Signal")
plt.plot(t, signal)

plt.subplot(2,1,2)
plt.title("Noisy Signal")
plt.plot(t, noisy_signal)

plt.tight_layout()
plt.show()
#  real noise signal generated
# Low-pass filter (Moving Average)
window_size = 5
filtered_signal = np.convolve(noisy_signal, np.ones(window_size)/window_size, mode='same')
# Additional filters for comparison
window_small = 5
window_large = 20

filtered_small = np.convolve(noisy_signal, np.ones(window_small)/window_small, mode='same')
filtered_large = np.convolve(noisy_signal, np.ones(window_large)/window_large, mode='same')
# High-pass filters (derived from low-pass)
high_pass_small = noisy_signal - filtered_small
high_pass_medium = noisy_signal - filtered_signal
high_pass_large = noisy_signal - filtered_large
plt.figure(figsize=(12,12))

plt.subplot(6,1,1)
plt.title("Noisy Signal")
plt.plot(t, noisy_signal)

plt.subplot(6,1,2)
plt.title("Low-pass (Window = 5)")
plt.plot(t, filtered_small)

plt.subplot(6,1,3)
plt.title("Low-pass (Window = 10)")
plt.plot(t, filtered_signal)

plt.subplot(6,1,4)
plt.title("Low-pass (Window = 20)")
plt.plot(t, filtered_large)

plt.subplot(6,1,5)
plt.title("High-pass (Window = 10)")
plt.plot(t, high_pass_medium)

plt.subplot(6,1,6)
plt.title("High-pass (Window = 20)")
plt.plot(t, high_pass_large)

plt.tight_layout()
plt.show()